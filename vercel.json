{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/cron", "destination": "/api/cron.js" },
    { "source": "/api/news", "destination": "/api/news.js" },
    { "source": "/api/send", "destination": "/api/send.js" },
    { "source": "/api/user", "destination": "/api/user.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 8 * * *"
    }
  ]
}
